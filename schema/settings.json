{
  "$schema": "https://json-schema.org/draft-07/schema",
  "minuteDebug.trace": {
    "type": "array",
    "markdownDescription": "Enable trace output for the listed components. Each entry is a trace tag (see `getTrace('tag')` in the source).",
    "items": {
      "type": "string"
    }
  },
  "minuteDebug.server": {
    "type": "object",
    "markdownDescription": "Named GDB server presets, referenced by name from the `server` field of a launch configuration.",
    "additionalProperties": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "qemu",
            "bmp"
          ],
          "description": "GDB server type."
        },
        "machine": {
          "type": "string",
          "markdownDescription": "QEMU machine to emulate (`qemu` only)."
        },
        "cpu": {
          "type": "string",
          "markdownDescription": "QEMU CPU to emulate (`qemu` only)."
        },
        "port": {
          "type": "string",
          "markdownDescription": "Serial port of the Black Magic Probe (`bmp` only). Auto-detected when omitted."
        },
        "power": {
          "type": "boolean",
          "markdownDescription": "Enable target power supplied by the probe (`bmp` only)."
        },
        "deviceId": {
          "$ref": "#/definitions/deviceId"
        },
        "manufacturer": {
          "$ref": "#/definitions/stringMatch"
        },
        "product": {
          "$ref": "#/definitions/stringMatch"
        },
        "serial": {
          "$ref": "#/definitions/stringMatch"
        }
      }
    },
    "definitions": {
      "deviceId": {
        "markdownDescription": "USB device to match by vendor/product id.",
        "oneOf": [
          {
            "$ref": "#/definitions/deviceIdValue"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/definitions/deviceIdValue"
            }
          }
        ]
      },
      "deviceIdValue": {
        "type": "object",
        "required": [
          "vid",
          "pid"
        ],
        "properties": {
          "vid": {
            "type": "integer"
          },
          "pid": {
            "type": "integer"
          }
        }
      },
      "stringMatch": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "minuteDebug.smu": {
    "type": "object",
    "markdownDescription": "Named source-measure unit (power supply) presets, referenced by name from the `smu` field of a launch configuration.",
    "additionalProperties": {
      "type": "object",
      "required": [
        "type",
        "output",
        "voltage"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "stlink"
          ],
          "description": "SMU type."
        },
        "port": {
          "type": "string",
          "description": "Serial port of the SMU. Auto-detected when omitted."
        },
        "output": {
          "type": "string",
          "description": "Output channel to drive.",
          "examples": [
            "vout",
            "vaux"
          ]
        },
        "voltage": {
          "type": "number",
          "description": "Output voltage in volts."
        },
        "startPowerOn": {
          "type": "boolean",
          "description": "Turn the output on when the debug session starts."
        },
        "stopPowerOff": {
          "type": "boolean",
          "description": "Turn the output off when the debug session ends."
        },
        "deviceId": {
          "$ref": "#/definitions/deviceId"
        },
        "manufacturer": {
          "$ref": "#/definitions/stringMatch"
        },
        "product": {
          "$ref": "#/definitions/stringMatch"
        },
        "serial": {
          "$ref": "#/definitions/stringMatch"
        },
        "index": {
          "markdownDescription": "Match the n-th matching port.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "array",
              "items": {
                "type": "integer"
              }
            }
          ]
        }
      }
    },
    "definitions": {
      "deviceId": {
        "markdownDescription": "USB device to match by vendor/product id.",
        "oneOf": [
          {
            "$ref": "#/definitions/deviceIdValue"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/definitions/deviceIdValue"
            }
          }
        ]
      },
      "deviceIdValue": {
        "type": "object",
        "required": [
          "vid",
          "pid"
        ],
        "properties": {
          "vid": {
            "type": "integer"
          },
          "pid": {
            "type": "integer"
          }
        }
      },
      "stringMatch": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "minuteDebug.swo": {
    "type": "object",
    "markdownDescription": "Named SWO/SWV trace presets, referenced by name from the `swo` field of a launch configuration.",
    "additionalProperties": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "bmp"
          ],
          "description": "SWO source type."
        },
        "cpuFrequency": {
          "type": "number",
          "description": "Target CPU frequency in Hz. 0 leaves the probe at its default."
        },
        "swvFrequency": {
          "type": "number",
          "description": "SWO/SWV bitrate in Hz."
        },
        "format": {
          "type": "integer",
          "enum": [
            1,
            2
          ],
          "markdownEnumDescriptions": [
            "Manchester",
            "UART"
          ],
          "description": "SWV encoding."
        },
        "port": {
          "type": "object",
          "markdownDescription": "USB interface carrying the SWO stream.",
          "properties": {
            "configuration": {
              "$ref": "#/definitions/stringMatch"
            },
            "interface": {
              "$ref": "#/definitions/stringMatch"
            },
            "deviceId": {
              "$ref": "#/definitions/deviceId"
            },
            "manufacturer": {
              "$ref": "#/definitions/stringMatch"
            },
            "product": {
              "$ref": "#/definitions/stringMatch"
            },
            "serial": {
              "$ref": "#/definitions/stringMatch"
            },
            "endpoints": {
              "type": "object",
              "properties": {
                "address": {
                  "type": "integer"
                },
                "type": {
                  "type": "integer",
                  "enum": [
                    0,
                    1,
                    2,
                    3
                  ],
                  "markdownEnumDescriptions": [
                    "Control",
                    "Isochronous",
                    "Bulk",
                    "Interrupt"
                  ]
                },
                "direction": {
                  "type": "integer",
                  "enum": [
                    0,
                    128
                  ],
                  "markdownEnumDescriptions": [
                    "Out",
                    "In"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "definitions": {
      "deviceId": {
        "markdownDescription": "USB device to match by vendor/product id.",
        "oneOf": [
          {
            "$ref": "#/definitions/deviceIdValue"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/definitions/deviceIdValue"
            }
          }
        ]
      },
      "deviceIdValue": {
        "type": "object",
        "required": [
          "vid",
          "pid"
        ],
        "properties": {
          "vid": {
            "type": "integer"
          },
          "pid": {
            "type": "integer"
          }
        }
      },
      "stringMatch": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "minuteDebug.defaults": {
    "type": "object",
    "markdownDescription": "Defaults merged into every launch configuration.",
    "properties": {
      "launch": {
        "type": "object",
        "markdownDescription": "Fields applied to a launch configuration when it does not specify them.",
        "properties": {
          "server": {
            "markdownDescription": "Default GDB server: a preset name from `minuteDebug.server` or an inline server configuration.",
            "type": [
              "string",
              "object"
            ]
          },
          "smu": {
            "markdownDescription": "Default SMU: a preset name from `minuteDebug.smu` or an inline SMU configuration.",
            "type": [
              "string",
              "object"
            ]
          },
          "swo": {
            "markdownDescription": "Default SWO: a preset name from `minuteDebug.swo` or an inline SWO configuration.",
            "type": [
              "string",
              "object"
            ]
          },
          "svd": {
            "markdownDescription": "Default SVD: a model name, or a list of `{ model, peripherals }` layers.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "model"
                  ],
                  "properties": {
                    "model": {
                      "type": "string"
                    },
                    "peripherals": {
                      "$ref": "#/definitions/stringMatch"
                    }
                  }
                }
              }
            ]
          },
          "cwd": {
            "type": "string",
            "description": "Default working directory."
          },
          "env": {
            "type": "object",
            "description": "Default environment variables.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "program": {
            "type": "string",
            "description": "Default program (ELF) to debug."
          },
          "smartLoad": {
            "type": "boolean",
            "description": "Only flash sections that differ from the device contents."
          }
        }
      }
    },
    "definitions": {
      "stringMatch": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
